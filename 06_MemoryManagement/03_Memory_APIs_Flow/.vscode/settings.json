{
  // Force Markdown Preview to follow the editor's dark color theme
  // instead of rendering with a white background.
  "workbench.colorTheme": "Dark Modern",
  // Clear any custom markdown stylesheets that might force a light background.
  "markdown.styles": [],
  // Ensure the preview inherits VS Code theme colors (dark).
  "markdown.preview.fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe WPC', 'Segoe UI', system-ui, 'Ubuntu', 'Droid Sans', sans-serif",
  "[markdown]": {
    "editor.wordWrap": "on",
    "editor.renderWhitespace": "all",
    "editor.quickSuggestions": {
      "comments": "off",
      "strings": "off",
      "other": "off"
    }
  },
  // ---- Markdown Preview Enhanced (shd101wyy.markdown-preview-enhanced) ----
  // Use a dark preview theme so the rendered page is no longer white.
  "markdown-preview-enhanced.previewTheme": "github-dark.css",
  "markdown-preview-enhanced.codeBlockTheme": "atom-dark.css",
  "markdown-preview-enhanced.revealjsTheme": "black.css",
  "markdown-preview-enhanced.printBackground": true,
  // ---- Markdown Preview Github Styling (bierner.markdown-preview-github-styles) ----
  // Force the GitHub-styled preview to use the dark color theme.
  "markdown-preview-github-styles.colorTheme": "dark"
}
